NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fsams
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173
ORG_EMAIL_DOMAIN=aiet.org.in

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="FSAMS Portal <no-reply@aiet.org.in>"

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@aiet.org.in
ADMIN_PASSWORD=replace-with-secure-admin-password
