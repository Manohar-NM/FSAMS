NODE_ENV=development
PORT=5000
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/fsams
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=1d
CLIENT_URL=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175
LOGIN_URL=http://localhost:5173
# Optional. Leave blank to allow Gmail/other valid email accounts.
ORG_EMAIL_DOMAIN=
UPLOAD_DIR=uploads/proofs
EMAIL_VALIDATION_TIMEOUT_MS=10000
EMAIL_SEND_TIMEOUT_MS=10000

EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM="FSAMS Portal <your-gmail-address@gmail.com>"

ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@aiet.org.in
ADMIN_PASSWORD=replace-with-secure-admin-password
